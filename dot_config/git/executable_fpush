#!/usr/bin/env bash
# Force-push the current branch and post a diff comment to the PR
# so reviewers can quickly see what changed between old and new tips.
#
# Usage:
#   fpush [--dry-run] [--no-push] [--no-comment] [<git-push-args>...]
#
# Accepts the same argument structure as `git push` (remote, refspec,
# -f/--force, --force-with-lease, etc.); such arguments are ignored.
#
# Requires: gh CLI (to resolve PR base branch).

set -euo pipefail

DRY_RUN=0
DO_PUSH=1
DO_COMMENT=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run)     DRY_RUN=1; DO_PUSH=0; DO_COMMENT=0; shift ;;
    --no-push)     DO_PUSH=0; shift ;;
    --no-comment)  DO_COMMENT=0; shift ;;
    -h|--help)     sed -n '2,9p' "$0"; exit 0 ;;
    *)             shift ;;
  esac
done

valid_ref() { [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._/-]*$ ]]; }

command -v gh  >/dev/null || { echo "gh not found" >&2; exit 1; }
command -v git >/dev/null || { echo "git not found" >&2; exit 1; }
command -v jq  >/dev/null || { echo "jq not found" >&2; exit 1; }

PR_JSON=$(gh pr view --json baseRefName,headRefName,number,title,isDraft)
BASE_REF=$(printf '%s' "$PR_JSON" | jq -r '.baseRefName')
HEAD_REF=$(printf '%s' "$PR_JSON" | jq -r '.headRefName')
PR_NUM=$(printf '%s'  "$PR_JSON" | jq -r '.number')
PR_TITLE=$(printf '%s' "$PR_JSON" | jq -r '.title')
PR_IS_DRAFT=$(printf '%s' "$PR_JSON" | jq -r '.isDraft')

if [ "$PR_IS_DRAFT" = "true" ] && [ "$DO_COMMENT" -eq 1 ]; then
  echo "PR #${PR_NUM} is Draft; skipping comment."
  DO_COMMENT=0
fi

valid_ref "$BASE_REF" || { echo "invalid baseRefName: $BASE_REF" >&2; exit 1; }
valid_ref "$HEAD_REF" || { echo "invalid headRefName: $HEAD_REF" >&2; exit 1; }

CURRENT=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT" != "$HEAD_REF" ]; then
  echo "current branch ($CURRENT) != PR head ($HEAD_REF)" >&2
  exit 1
fi

git fetch origin --quiet

OLD_TIP=$(git rev-parse "origin/${HEAD_REF}")
NEW_TIP=$(git rev-parse HEAD)

if [ "$OLD_TIP" = "$NEW_TIP" ]; then
  echo "HEAD == origin/${HEAD_REF} (${OLD_TIP}). Nothing to push." >&2
  exit 0
fi

if git merge-base --is-ancestor "$OLD_TIP" "$NEW_TIP"; then
  echo "HEAD is a fast-forward of origin/${HEAD_REF}. force-push not needed; use plain 'git push'." >&2
  exit 0
fi

echo "PR      : #${PR_NUM} ${PR_TITLE}"
echo "old tip : ${OLD_TIP}  (origin/${HEAD_REF})"
echo "new tip : ${NEW_TIP}  (HEAD)"
echo

if [ "$DRY_RUN" -eq 1 ]; then
  echo "(dry-run) would push force-with-lease origin ${HEAD_REF}"
  exit 0
fi

if [ "$DO_PUSH" -eq 1 ]; then
  SKIP_FPUSH_HOOK=1 git push --force-with-lease --force-if-includes origin -- "$HEAD_REF"
else
  echo "--no-push: skipping git push. Run manually:"
  echo "  git push --force-with-lease --force-if-includes origin ${HEAD_REF}"
fi

CMD="git fetch origin && git diff ${OLD_TIP} ${NEW_TIP}"
DIFF_OUTPUT=$(git diff --no-color "${OLD_TIP}" "${NEW_TIP}" 2>&1 || true)
SHORTSTAT=$(git diff --shortstat "${OLD_TIP}" "${NEW_TIP}" 2>/dev/null || true)

if [ -z "$DIFF_OUTPUT" ]; then
  HEADER="force-push しました (差分なし)"
else
  # e.g. " 3 files changed, 12 insertions(+), 5 deletions(-)"
  ADDED=$(printf '%s' "$SHORTSTAT" | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo 0)
  REMOVED=$(printf '%s' "$SHORTSTAT" | grep -oE '[0-9]+ deletion'  | grep -oE '[0-9]+' || echo 0)
  HEADER="force-push しました (差分あり +${ADDED:-0} -${REMOVED:-0})"
fi

# Markdown コードフェンスは、本文中の最長バッククォート連続より長くしないと
# 差分内にバッククォートが含まれる場合にフェンスが途中で閉じてしまう。
MAX_BACKTICK_RUN=$(printf '%s\n%s' "$CMD" "$DIFF_OUTPUT" | grep -oE '`+' | wc -L || true)
FENCE_LEN=$((MAX_BACKTICK_RUN + 1))
[ "$FENCE_LEN" -lt 3 ] && FENCE_LEN=3
FENCE=$(printf '%*s' "$FENCE_LEN" '' | tr ' ' '`')

# ファイルごとに見出しを付け、diff --git/index/---/+++ の各行を除いた
# ハンク本体 (@@ 以降) だけをコードブロックに残す。
FILES_DIFF_BODY=$(printf '%s\n' "$DIFF_OUTPUT" | awk -v fence="$FENCE" '
function flush() {
  if (path == "") return
  if (first) { first = 0 } else { print "" }
  if (renamed) {
    print "#### `" path "` (renamed from `" old_path "`)"
  } else if (is_new) {
    print "#### `" path "` (new file)"
  } else if (is_deleted) {
    print "#### `" path "` (deleted)"
  } else {
    print "#### `" path "`"
  }
  print ""
  if (binary) {
    print "*(バイナリファイルのため差分表示なし)*"
  } else if (hunk_n == 0) {
    print "*(内容の差分なし)*"
  } else {
    print fence "diff"
    for (i = 1; i <= hunk_n; i++) print hunk[i]
    print fence
  }
}
BEGIN { first = 1 }
/^diff --git a\// {
  flush()
  line = $0
  sub(/^diff --git a\//, "", line)
  split(line, parts, " b/")
  old_path = parts[1]
  path = parts[2]
  is_new = 0; is_deleted = 0; renamed = 0; binary = 0
  hunk_n = 0
  next
}
/^new file mode/      { is_new = 1; next }
/^deleted file mode/  { is_deleted = 1; next }
/^rename from /       { renamed = 1; next }
/^rename to /          { next }
/^similarity index/    { next }
/^old mode/            { next }
/^new mode/            { next }
/^index /              { next }
/^--- /                { next }
/^\+\+\+ /             { next }
/^Binary files/         { binary = 1; next }
{ hunk_n++; hunk[hunk_n] = $0 }
END { flush() }
')

COMMENT_BODY=$(cat <<EOF
${HEADER}

<details><summary>差分確認</summary>

${FENCE}bash
${CMD}
${FENCE}

${FILES_DIFF_BODY}

</details>
EOF
)

if [ "$DO_COMMENT" -eq 1 ] && [ "$DO_PUSH" -eq 1 ]; then
  printf '%s\n' "$COMMENT_BODY" | gh pr comment "$PR_NUM" --body-file -
  echo
  echo "posted comment to PR #${PR_NUM}"
else
  echo
  echo "===== PR comment (copy below) ====="
  printf '%s\n' "$COMMENT_BODY"
  echo "==================================="
fi
